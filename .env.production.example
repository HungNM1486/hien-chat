# Production environment — copy to .env at repo root and fill secrets
#
# Deploy:
#   docker network create legal-shared-network
#   docker compose -f docker/docker-compose.prod.yml up -d --build
#   docker compose -f docker/docker-compose.prod.yml --profile setup run --rm migrate

POSTGRES_PASSWORD=change-me
MINIO_ROOT_PASSWORD=change-me

DATABASE_URL=postgres://hiennha:change-me@postgres:5432/hiennha
REDIS_URL=redis://redis:6379

JWT_SECRET=change-me-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Public URLs (same origin khi nginx proxy cả web + API)
WEB_PUBLIC_URL=https://your-domain.com
API_PUBLIC_URL=https://your-domain.com
NEXT_PUBLIC_API_URL=https://your-domain.com
CORS_ORIGIN=https://your-domain.com

# WebRTC TURN (coturn — voice call qua NAT/4G)
# DNS: TURN_HOST (vd. turn.your-domain.com) → A record cùng IP VPS
# Firewall: TCP+UDP 3478, UDP 49160-49200
TURN_REALM=your-domain.com
TURN_HOST=turn.your-domain.com
TURN_USERNAME=hiennha
TURN_PASSWORD=change-me-long-random-turn-secret
# Bắt buộc nếu VPS có IP public khác IP private (cloud NAT)
# TURN_EXTERNAL_IP=203.0.113.10
# Tùy chọn — mặc định compose dùng turn:${TURN_HOST}:3478 lúc build web
# NEXT_PUBLIC_TURN_URL=turn:turn.your-domain.com:3478

# Docker shared network với reverse proxy (nginx/Caddy)
SHARED_NETWORK_NAME=legal-shared-network

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
REQUIRE_INVITE=true
