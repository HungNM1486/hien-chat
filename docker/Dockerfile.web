FROM node:22-alpine AS base
RUN corepack enable && corepack prepare pnpm@10.12.1 --activate
WORKDIR /app

FROM base AS deps
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY apps/web/package.json ./apps/web/
COPY packages/shared/package.json ./packages/shared/
COPY packages/theme/package.json ./packages/theme/
COPY packages/crypto/package.json ./packages/crypto/
RUN pnpm install --frozen-lockfile --filter @hien-nha/web...

FROM base AS builder
ARG NEXT_PUBLIC_API_URL=https://example.com
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY apps/web/package.json ./apps/web/
COPY packages/shared/package.json ./packages/shared/
COPY packages/theme/package.json ./packages/theme/
COPY packages/crypto/package.json ./packages/crypto/
RUN pnpm install --frozen-lockfile --filter @hien-nha/web...
COPY . .
ENV NEXT_TELEMETRY_DISABLED=1
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
RUN pnpm --filter @hien-nha/shared build \
 && pnpm --filter @hien-nha/theme build \
 && pnpm --filter @hien-nha/crypto build \
 && pnpm --filter @hien-nha/web build

FROM node:22-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /app/apps/web/public ./apps/web/public
EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
CMD ["node", "apps/web/server.js"]
