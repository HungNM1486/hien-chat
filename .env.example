# Server
PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://hiennha:hiennha@localhost:5432/hiennha
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production-use-long-random-string
